# Copy this file to .env and fill in your real key.
# Get a key at https://console.anthropic.com/settings/keys

ANTHROPIC_API_KEY=sk-ant-replace-me

# Optional: override the default model.
# claude-opus-4-7    -> most capable, best for realistic panel feel (~$0.50 per interview)
# claude-sonnet-4-6  -> fast + cheap with prompt caching       (~$0.05 per interview)
# claude-haiku-4-5   -> cheapest, less nuanced                  (~$0.02 per interview)
ANTHROPIC_MODEL=claude-opus-4-7
